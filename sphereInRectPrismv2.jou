############################################## sphere in cube 3D
reset
############################################## geometry - single pebble
# {L = 0.7}
# {D = 0.25} 
# {R = D/2}
# {box = 3*R}

brick x {0.5} y {L} z {L}
create sphere radius {R}
brick x {box} y {box} z {box}

move Volume 2 3 y -0.125 include_merged 
subtract volume 2 from volume 1 3 imprint 
chop volume 4  with volume 5 

webcut volume 7  with plane from surface 11 
webcut volume 7  with plane from surface 13  
webcut volume 7 8 9  with plane from surface 8  
webcut volume 10 11 12 with plane from surface 9  
webcut volume 7 8 9 10 11 12 14 15 16 with plane from surface 12  
webcut volume 7 8 9 10 11 12 13 15 16 with plane from surface 10  

################################################################### mesh pebble
# group the outer layer
picked add Volume 21 Volume 12 Volume 10 Volume 25 Volume 24 Volume 7 Volume 23 Volume 8 Volume 9 Volume 20 Volume 29 Volume 18 Volume 11 Volume 22 Volume 30 Volume 27 Volume 15 Volume 19 Volume 32 Volume 17 Volume 28 Volume 14 Volume 16 Volume 13 Volume 31 Volume 26 
group picked visibility off

webcut volume 6  with plane xplane offset 0 
webcut volume 6  with plane yplane offset -0.125  
webcut volume 6  with plane zplane offset 0 
delete volume 33 to 35

volume 6  scheme polyhedron 
volume 6 size auto factor 5 propagate 
mesh volume 6


Volume 6 copy reflect x 
Volume 6 36 copy reflect vertex 229 220 
Volume 6 36 37 38 copy reflect z 

merge all
unite volume 6 36 37 38 39 40 41 42 include_mesh 

group picked visibility on

################################################################### mesh outside
merge all

# top
curve 79 interval 6 scheme bias 1.2 start vertex 19
mesh curve 79
propagate curve bias Volume 14 17 18 19 20 21 22 23 24

volume 14 redistribute nodes off 
volume 14 scheme Sweep sweep transform least squares 
volume 14 autosmooth target on  fixed imprints off  smart smooth off 
mesh volume 14


# bottom
volume 13 redistribute nodes off 
volume 13 scheme Sweep sweep transform least squares 
volume 13 autosmooth target on  fixed imprints off  smart smooth off 
volume 13 interval 2
mesh volume 13

# sides
volume 7 10 11 12 redistribute nodes off 
volume 7 10 11 12 scheme Sweep sweep transform least squares 
volume 7 10 11 12 autosmooth target on  fixed imprints off  smart smooth off 
volume 7 10 11 12 interval 3
mesh volume 7 10 11 12

# corners
volume 18 17 19 22 24 20 23 21 9 27 30 32 16 25 26 8 29 31 28 15 scheme auto 
mesh volume 18 17 19 22 24 20 23 21 9 27 30 32 16 25 26 8 29 31 28 15

#draw hex all

############################################################ boundaries
block 1 add volume all 
block 1 element type HEX20

# left
sideset 1 add surface 121 151 169 195 201 225 231 247 249
sideset 1 name "left"

# right
sideset 2 add surface 129 159 181 207 209 237 239 255 261
sideset 2 name "right"

# top
sideset 3 add surface 42 52 62 76 82 87 89 97 99
sideset 3 name "top"

# bottom
sideset 4 add surface 43 54 64 73 79 85 91 95 101
sideset 4 name "bottom"

# front
sideset 5 add surface 112 122 132 185 191 196 200 206 210
sideset 5 name "front"

# back
sideset 6 add surface 142 172 182 215 221 246 250 256 260
sideset 6 name "back"

# sphere
sideset 7 add surface 291
sideset 7 name "sphere"

# export mesh as exodus file
#set exodus netcdf4 off
#set large exodus file on
#export mesh "/home/hailu/Desktop/sphere_in_cubev2.exo"  dimension 3  overwrite 


