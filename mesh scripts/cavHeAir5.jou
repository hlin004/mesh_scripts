###################################################################
###
reset
###ALL NUMBERS ARE NON-Dimensional################################# Geometry
# {do_pause = 0}
# {x_cav = 43.9} 
# {y_cav = 43.9}
# {z_cav = 129.9}

# {inj_loc = 30.50725}
# {rad_pipe = 0.5}
# {sol_loc = 2.753623}
# {sol_rad_pipe = 0.4601}

#Cavity Geometry
brick x {x_cav} y {y_cav} z {z_cav}
move volume 1 z {z_cav/2} include_merged

#Injection Pipe 
create cylinder height {y_cav+4.05*2} radius {rad_pipe}
rotate volume 2 angle 90 about x include_merged
move Volume 2 z {inj_loc} include_merged

#outlet Pipe 
create cylinder height {y_cav+4.05*2} radius {sol_rad_pipe}
rotate volume 3 angle 90 about x include_merged
move Volume 3 z {sol_loc} include_merged

#injection cone
create frustum height {y_cav} radius {rad_pipe} top 2.5
rotate volume 4 angle 270 about x include_merged
move Volume 4 z {inj_loc} include_merged

webcut volume 2 3  with plane from surface 5  
webcut volume 2 3  with plane from surface 3  
delete volume 2 5 8

#injection outer cylinder
create Cylinder height {y_cav} radius 5
rotate Volume 9  angle 90  about X include_merged  
move Volume 9  z {inj_loc} include_merged  

#injection outer box
brick x 18 y {y_cav} z 18
move volume 10 z {inj_loc} include_merged

#outlet outer box
brick x 3 y {y_cav} z 3
move volume 11 z {sol_loc} include_merged

remove overlap volume 1 10 modify volume 1
remove overlap volume 1 11 modify volume 1
remove overlap volume 10 9 modify volume 10
remove overlap volume 11 3 modify volume 11
remove overlap volume 9 4 modify volume 9

#webcut top
webcut volume 1  with plane from surface 55  
webcut volume 1  with plane from surface 56  
webcut volume 1 17 18  with plane from surface 53  
webcut volume 19 20 21  with plane from surface 54  

#webcut bottom
webcut volume 19 22 23  with plane from surface 65  
webcut volume 24 25 26  with plane from surface 66  

#webcut mid and back
webcut volume 19 22 23  with plane zplane offset 12
webcut volume all with plane yplane offset 6 

imprint all
merge all
############################################################################ Mesh
picked add Volume 17 Volume 18 Volume 1 Volume 20 Volume 21 Volume 23 Volume 19 Volume 22 Volume 32 Volume 31 Volume 33 Volume 26 Volume 28 Volume 27 Volume 24 Volume 25 Volume 29 Volume 30 
picked add Volume 34 Volume 41 Volume 40 Volume 44 Volume 43 Volume 45 Volume 42 Volume 46 Volume 56 Volume 54 Volume 55 Volume 48 Volume 50 Volume 51 Volume 49 Volume 53 Volume 47 Volume 52 
group 1 rename "cavity1"
cavity1 visibility off
#######################################
# {cav_front_int = 28}
# {cav_front_bias = 1.05}
# {in_pipe_int = 8}
# {in_pipe_bias = 1.05}
#pipe cav inner
create vertex on curve 689  start 
create vertex on curve 375  start 
create curve vertex 401 402  
project curve 741  onto volume 10  target surface 258  imprint 
curve 742  interval {cav_front_int}
curve 742  scheme bias factor {cav_front_bias} start vertex 15 
mesh curve 742 
delete curve 741

create boundary_layer 1
modify boundary_layer 1 uniform height 0.05 growth 1.2 layers 2
modify boundary_layer 1 add curve 19 surface 16 
modify boundary_layer 1 continuity on

curve 19  interval 16
curve 19  scheme equal
mesh curve 19 







