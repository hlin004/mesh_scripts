unite volume all include_mesh

block 1 add volume 3
block 1 element type HEX20

#Add SideSets

#inlet
sideset 1 add surface 53 
sideset 1 name "inlet"

#inlet pipe
sideset 2 add surface 54
sideset 2 name "inlet_pipe"

#Cavity-Inlet Wall
sideset 3 add surface 35
sideset 3 name "cavity_inlet_pipe"

#Cavity Wall - Across from Pipe
sideset 4 add surface 36
sideset 4 name "cavity_wall_pipe"

#Cavity Wall - East
sideset 5 add surface 143
sideset 5 name "cavity_wall_east"

#Cavity Wall - West
sideset 6 add surface 163
sideset 6 name "cavity_wall_west"

#Cavity Wall - Top
sideset 7 add surface 214
sideset 7 name "cavity_wall_top"

#Cavity Wall - Bottom
sideset 8 add surface 120
sideset 8 name "cavity_wall_bottom"

#export
set exodus netcdf4 off
set large exodus file on
export mesh "/Users/spatel/Desktop/Projects/2024/NEUP/meshing/FCnoSolValve_100k.exo"  dimension 3  overwrite 