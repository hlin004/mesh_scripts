#Cavity Geometry
brick x {x_cav} y {y_cav} z {z_cav}
move volume 1 z 64.95 include_merged

#Injection Pipe at Arbitrary Size
create cylinder height 64 radius {rad_pipe}
rotate volume 2 angle 90 about x include_merged
move Volume 2 z {inj_loc} include_merged 
Volume 2 scale X 1.0 Y 1.2 Z 1.0 

#Create Shear Layer
#{thick1=0.1}
#{rada = 0.5}
#{radb = rada - thick1}
create frustum height {y_cav-10.0} radius {rada} top {rad_pipe}

rotate volume 3 angle 90 about x include_merged
move Volume 3 x 0 y -5 z 0 include_merged 
move Volume 3 z {inj_loc} include_merged

delete volume 2

sweep surface 12  vector 0 -1 0  distance 26 
sweep surface 11  vector 0 1 0  distance 20 

webcut volume 3  with plane from surface 5  
webcut volume 3  with plane from surface 3  

delete volume 4

create surface curve 16  

webcut volume 3  with plane from surface 21 
delete body 6

subtract volume 3 7 from volume 1 keep

delete volume 1
create Cylinder height 64 radius 4
rotate Volume 9  angle 90  about X include_merged preview 
rotate Volume 9  angle 90  about X include_merged 
move Volume 9  z 30.50725 include_merged preview 
move Volume 9  z 30.50725 include_merged 
intersect volume 8 9 keep  preview 
intersect volume 8 9 keep 
subtract volume 9 from volume 8  keep 
delete Volume 9
delete Volume 8
webcut volume 10 with plane from surface 23  

create curve vertex 19 12
create curve vertex 48 36

imprint volume 7 with curve 69
imprint volume 10 with curve 70

