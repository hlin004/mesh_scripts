# 2D cavity
###################################################################
reset
#################################################
create vertex -26 	31.007250	0
create vertex -21.95 	31.007250	0
create vertex -21.95	129.900000 	0
create vertex 21.95	129.900000	0
create vertex 21.95	31.007250	0
create vertex 21.95	30.007250	0
create vertex 21.95	3.253623 	0
create vertex 26	3.253623 	0
create vertex 26	2.253623 	0
create vertex 21.95	2.253623 	0
create vertex 21.95	0 	0
create vertex -21.95	0	0
create vertex -21.95	2.253623	0
create vertex -21.95	3.253623	0
create vertex -21.95	30.007250	0
create vertex -26	30.007250	0

create surface vertex 1 2 15 16
create surface vertex 2 3 4 5
create surface vertex 2 5 6 15
create surface vertex 15 6 7 14
create surface vertex 14 7 10 13
create surface vertex 7 8 9 10
create surface vertex 13 10 11 12
split surface 2  offset curve 8  distance 10 
split surface 4  offset curve 11  distance 10 

imprint all
merge all

###########################################################################
# Mesh
####################### vertical direction
# inlet pipe
curve 4 2 10 interval 10 scheme dualbias 1.2
mesh curve 4 2 10

# jet top
curve 31 30 interval 25 scheme bias 1.1 start vertex 2 5
mesh curve 31 30

# jet bot
curve 35 36 interval 25 scheme bias 1.1 start vertex 6 15
mesh curve 35 36

# top cavity
curve 32 33 interval 10 scheme bias 1.3 start vertex 30 29
mesh curve 32 33

# mid cavity
curve 38 37 interval 8 scheme dualbias 1.7 
mesh curve 38 37

# bot cavity
curve 28 26 interval 5 scheme dualbias 1.4
mesh curve 28 26

# outlet pipe
curve 20 18 22 interval 5 scheme dualbias 1.2
mesh curve 20 18 22

################### horizontal direction
# inlet pipe
curve 1 3 size 0.5 scheme equal
mesh curve 1 3

# outlet pipe
curve 21 23 size 0.5 scheme equal
mesh curve 21 23

# cavity
curve 6 8 11 15 19 27 29 34 size .6 scheme dualbias 1.03
mesh curve 6 8 11 15 19 27 29 34

mesh surface all

###########################################################################
block 1 add surface all
block 1 element type QUAD8

# inlet
sideset 1 add curve 4
sideset 1 name "inlet"

# outlet
sideset 2 add curve 22
sideset 2 name "outlet"

# walls
sideset 3 add curve 6 10 20 21 23 26 27 28 30 31 32 33 35 36 37 38
sideset 3 name "walls"

# inlet pipe wall
sideset 4 add curve 1 3
sideset 4 name "inlet_pipe_wall"

# export mesh as exodus file
set exodus netcdf4 off
set large exodus file on
export mesh "/home/hailu/Desktop/fc_2D_6544.exo"  dimension 2  overwrite 

