# 2D cavity
###################################################################
reset
#################################################
# {y_cav = 43.9}
# {z_cav = 129.9}
# {inj_dia = 1}
# {out_dia = 0.9202}


# creat cavity
create surface rectangle width {y_cav} height {z_cav}
rotate surface 1 angle 90 about y include_merged
rotate surface 1 angle 90 about x include_merged
move surface 1 z 64.95 include_merged

# create inlet pipe
create surface rectangle width {inj_dia} height 64
rotate surface 2 angle 90 about y include_merged
move surface 2 z 30.50725 include_merged 
# move surface 2 y {-21.95-4} z 30.50725 include_merged 

# create outlet pipe
create surface rectangle width {out_dia} height 64
rotate surface 3 angle 90 about y include_merged
move surface 3 z 2.753623 include_merged 
# move surface 3 y {21.95+4} z 2.753623 include_merged 

webcut body 2 3 with sheet body 1
webcut body 1 with sheet body 4
webcut body 12 with sheet body 5
delete body 6 9 10 13

imprint all
merge all

####################################################################### Mesh
####################### vertical direction
# inlet pipe
curve 7 16 21 interval 10 scheme dualbias 1.2
mesh curve 7 16 21

# top cavity
curve 35 34 interval 20 scheme bias 1.3 start vertex 16 20
mesh curve 35 34

# mid cavity
curve 45 44 interval 20 scheme dualbias 1.4 
mesh curve 45 44

# bot cavity
curve 47 48 interval 5 scheme bias 1.4 start vertex 25 22
mesh curve 47 48

# outlet pipe
curve 9 23 29 interval 10 scheme dualbias 1.2
mesh curve 9 23 29 

################### horizontal direction
# inlet pipe
curve 17 18 size 1 scheme equal
mesh curve 17 18 

# outlet pipe
curve 25 24 size 1 scheme equal
mesh curve 25 24

# cavity
curve 1 22 20 32 30 3 size 2 scheme dualbias 1.05
mesh curve 1 22 20 32 30 3 

mesh surface 10 6 13 9 14 5 7
###############################################################re-orient to xy plane
rotate Surface all angle -90  about Y include_merged 
rotate Surface all angle -90  about Z include_merged 
###########################################################################
block 1 add surface all
block 1 element type QUAD8

# inlet
sideset 1 add curve 7
sideset 1 name "inlet"

# outlet
sideset 2 add curve 9
sideset 2 name "outlet"

# walls
sideset 3 add curve 35 1 34 21 44 48 3 47 29 45 24 25 
sideset 3 name "walls"

# inlet pipe wall
sideset 4 add curve 17 18 
sideset 4 name "inlet_pipe_wall"

# export mesh as exodus file
set exodus netcdf4 off
set large exodus file on
export mesh "/home/hailu/Desktop/fc_2D_v3.exo"  dimension 2  overwrite 

#Executive Exodus summary:
#  Number of dimensions     = 2
#  Number of element blocks = 1
#  Number of sidesets       = 4
#  Number of nodesets       = 0
#  Number of bc sets        = 1
#  Number of elements       = 1630
#  Number of nodes          = 5105







