# 2D cavity
###################################################################
reset
#################################################
create vertex -32 	31.007250	0
create vertex -21.95 	31.007250	0
create vertex -21.95	129.900000 	0
create vertex 21.95	129.900000	0
create vertex 21.95	31.007250	0
create vertex 21.95	30.007250	0
create vertex 21.95	3.253623 	0
create vertex 32	3.253623 	0
create vertex 32	2.253623 	0
create vertex 21.95	2.253623 	0
create vertex 21.95	0 	0
create vertex -21.95	0	0
create vertex -21.95	2.253623	0
create vertex -21.95	3.253623	0
create vertex -21.95	30.007250	0
create vertex -32	30.007250	0

create surface vertex 1 2 15 16
create surface vertex 2 3 4 5
create surface vertex 2 5 6 15
create surface vertex 15 6 7 14
create surface vertex 14 7 10 13
create surface vertex 7 8 9 10
create surface vertex 13 10 11 12

imprint all
merge all

###########################################################################
# Mesh
####################### vertical direction
# inlet pipe
curve 4 2 10 interval 10 scheme dualbias 1.2
mesh curve 4 2 10

# top cavity
curve 5 7 interval 20 scheme bias 1.3 start vertex 2 5
mesh curve 5 7

# mid cavity
curve 16 14 interval 20 scheme dualbias 1.4 
mesh curve 16 14

# bot cavity
curve 28 26 interval 5 scheme dualbias 1.4
mesh curve 28 26

# outlet pipe
curve 20 18 22 interval 10 scheme dualbias 1.2
mesh curve 20 18 22

################### horizontal direction
# inlet pipe
curve 1 3 size 1 scheme equal
mesh curve 1 3

# outlet pipe
curve 21 23 size 1 scheme equal
mesh curve 21 23

# cavity
curve 6 8 11 15 19 27 size 2 scheme dualbias 1.05
mesh curve 6 8 11 15 19 27

mesh surface 1 2 3 4 5 6 7

###########################################################################
block 1 add surface all
block 1 element type QUAD8

# inlet
sideset 1 add curve 4
sideset 1 name "inlet"

# outlet
sideset 2 add curve 22
sideset 2 name "outlet"

# inlet pipe wall
sideset 3 add curve 1 3
sideset 3 name "inlet_pipe_wall"

# walls
sideset 4 add curve 5 6 7 10 14 16 20 21 23 26 27 28
sideset 4 name "walls"

# export mesh as exodus file
set exodus netcdf4 off
set large exodus file on
export mesh "/home/hailu/Desktop/fc_2D.exo"  dimension 2  overwrite 













